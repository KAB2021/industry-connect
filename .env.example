# Database connection URLs
# Local development: use postgresql://<your-username>@localhost:5432/<db-name>
# Docker/production: use postgresql://<user>:<password>@<host>:<port>/<db-name>
DATABASE_URL=postgresql://appuser:apppassword@localhost:5432/industryconnect
TEST_DATABASE_URL=postgresql://appuser:apppassword@localhost:5432/industryconnect_test

# OpenAI credentials
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Background polling configuration
# How often to poll the source URL (in seconds)
POLL_INTERVAL_SECONDS=60
# The URL to poll for new job listings
POLL_SOURCE_URL=https://example.com/jobs

# File upload limits
# Maximum size in bytes for uploaded files (default: 10 MB)
MAX_UPLOAD_BYTES=10485760

# Token threshold for OpenAI requests (default: 4000)
TOKEN_THRESHOLD=4000
